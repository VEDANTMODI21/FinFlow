# Email Service Configuration
# Choose ONE of these email providers to enable email sending:

# 1. Resend (https://resend.com) - Modern email API (RECOMMENDED)
# Sign up at https://resend.com and get your API key
RESEND_API_KEY=

# 2. Brevo (formerly Sendinblue) - Alternative SMTP option
# Sign up at https://www.brevo.com
BREVO_API_KEY=

# Email Sender Configuration
SENDER_EMAIL=onboarding@resend.dev
SENDER_NAME=FinFlow Secure Auth

# Application Settings
PORT=3000
NODE_ENV=production

# Note: In development mode without API keys, OTP codes will be logged to console
# For production, ensure RESEND_API_KEY or BREVO_API_KEY is configured
